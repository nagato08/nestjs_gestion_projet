# ============================================
# Application
# ============================================
NODE_ENV=production
PORT=4000

# ============================================
# Base de données PostgreSQL
# ============================================
POSTGRES_DB=tuto_db
POSTGRES_USER=tuto_user
POSTGRES_PASSWORD=changeme_strong_password

# DATABASE_URL doit pointer vers le service "postgres" (nom du conteneur)
DATABASE_URL=postgresql://tuto_user:changeme_strong_password@postgres:5432/tuto_db?schema=public

# ============================================
# Auth — JWT
# ============================================
# Générer avec : openssl rand -hex 64
JWT_SECRET=replace_with_64_bytes_hex_random

# ============================================
# CORS — origines autorisées (séparées par virgules)
# ============================================
CORS_ORIGIN=https://forge.tadjo.dev,https://portfolio.tadjo.dev

# ============================================
# URL publique du frontend (pour liens d'emails, redirections, etc.)
# ============================================
FRONTEND_BASE_URL=https://forge.tadjo.dev

# ============================================
# Services externes
# ============================================
OPENAI_API_KEY=sk-proj-XXXXX
RESEND_API_KEY=re_XXXXX
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
